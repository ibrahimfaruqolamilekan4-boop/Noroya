# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Flutterwave API Settings
FLUTTERWAVE_PUBLIC_KEY="PASTE_YOUR_FLUTTERWAVE_PUBLIC_KEY_HERE"
FLUTTERWAVE_SECRET_KEY="PASTE_YOUR_FLUTTERWAVE_SECRET_KEY_HERE"
FLW_SECRET_HASH="PASTE_YOUR_FLUTTERWAVE_WEBHOOK_SECRET_HASH_HERE"

# VTU Bigisub and Failover Backup Configurations
BIGISUB_API_KEY="PASTE_YOUR_BIGISUB_API_KEY_HERE"
BIGISUB_BASE_URL="https://www.bigisub.ng/api/v1"
BACKUP_VTU_API_KEY="cheapdatahub_backup_simulation_secret_key"

# Paystack API Settings
PAYSTACK_LIVE_PUBLIC_KEY=
PAYSTACK_LIVE_SECRET_KEY=
PAYSTACK_PUBLIC_KEY="PASTE_YOUR_PAYSTACK_PUBLIC_KEY_HERE"
PAYSTACK_SECRET_KEY="PASTE_YOUR_PAYSTACK_SECRET_KEY_HERE"

# VTU Provider Integrations API settings
VTU_API_KEY="peyflex_primary_wholesale_vtu_secret_key"
VTU_API_SECRET="your_vtu_api_secret_keys"
VTU_BASE_URL="https://api.vtuprovider.com/v1"

# Database Configuration and Authorization
MONGODB_URI="your_mongodb_connection"
JWT_SECRET="noroya-vtu-jwt-auth-token-super-key!"

# Supabase PostgreSQL Configuration
SUPABASE_URL="https://your-supabase-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key-bypass-rls"
VITE_SUPABASE_URL="https://your-supabase-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# OPay Merchant Credentials
OPAY_MERCHANT_ID="PASTE_YOUR_OPAY_MERCHANT_ID_HERE"
OPAY_SECRET_KEY="PASTE_YOUR_OPAY_SECRET_KEY_HERE"
OPAY_PUBLIC_KEY="PASTE_YOUR_OPAY_PUBLIC_KEY_HERE"





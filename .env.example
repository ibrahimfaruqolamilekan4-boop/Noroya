# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Monnify API Integration (Developer Credentials)
# Paste your keys directly inside the Secrets panel in AI Studio Settings.
NEXT_PUBLIC_MONNIFY_API_KEY="PASTE_YOUR_API_KEY_HERE"
MONNIFY_SECRET_KEY="PASTE_YOUR_SECRET_KEY_HERE"
NEXT_PUBLIC_MONNIFY_CONTRACT_CODE="PASTE_YOUR_CONTRACT_CODE_HERE"
MONNIFY_BASE_URL="https://sandbox.monnify.com"

# VTU Peyflex and Failover Backup Configurations
PEYFLEX_API_KEY="peyflex_primary_wholesale_vtu_secret_key"
BACKUP_VTU_API_KEY="cheapdatahub_backup_simulation_secret_key"

# Paystack API Settings
PAYSTACK_LIVE_PUBLIC_KEY=
PAYSTACK_LIVE_SECRET_KEY=
PAYSTACK_PUBLIC_KEY="PASTE_YOUR_PAYSTACK_PUBLIC_KEY_HERE"
PAYSTACK_SECRET_KEY="PASTE_YOUR_PAYSTACK_SECRET_KEY_HERE"

# VTU Provider Integrations API settings
VTU_API_KEY="peyflex_primary_wholesale_vtu_secret_key"
VTU_API_SECRET="your_vtu_api_secret_keys"
VTU_BASE_URL="https://api.vtuprovider.com/v1"

# Database Configuration and Authorization
MONGODB_URI="your_mongodb_connection"
JWT_SECRET="noroya-vtu-jwt-auth-token-super-key!"

# OPay Merchant Credentials
OPAY_MERCHANT_ID="PASTE_YOUR_OPAY_MERCHANT_ID_HERE"
OPAY_SECRET_KEY="PASTE_YOUR_OPAY_SECRET_KEY_HERE"
OPAY_PUBLIC_KEY="PASTE_YOUR_OPAY_PUBLIC_KEY_HERE"




